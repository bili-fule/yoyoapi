# Server
PORT=3001
HOST=0.0.0.0

# Database (SQLite)
DB_PATH=./data/yoyoapi.db

# SMTP (for email verification codes — leave empty to print codes to console in dev mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yoyoapi.com

# Admin account (created automatically on first start — CHANGE THESE!)
ADMIN_EMAIL=admin@yoyoapi.com
ADMIN_PASSWORD=your-strong-password-here

# QQ Bot (AstrBot integration — optional)
QQ_BOT_BASE_URL=
QQ_REQUIRED=false

# CORS (for separated frontend-backend deployment)
# Set to your frontend domain in separated mode, e.g. https://yoyoapi.example.com
# Default '*' allows all origins (monolithic mode)
CORS_ORIGIN=*

# Static file serving
# Set to false when frontend is hosted separately (Cloudflare Pages, GitHub Pages)
# Default true for monolithic deployment (Express serves the built Next.js static files)
SERVE_STATIC=true
